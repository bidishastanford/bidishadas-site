---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Bidisha Das — Economist at the IMF. Research on the future of money: crypto, stablecoins, CBDCs, and tokenization." } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = `${siteUrl}${path === '/' ? '' : path}`;
const ogImage = `${siteUrl}/bidisha.jpg`;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Bidisha Das',
  url: siteUrl || undefined,
  image: ogImage,
  jobTitle: 'Economist',
  worksFor: { '@type': 'Organization', name: 'International Monetary Fund' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Stanford University' },
    { '@type': 'CollegeOrUniversity', name: 'Shri Ram College of Commerce, University of Delhi' },
  ],
  sameAs: [
    'https://www.linkedin.com/in/bidishaimf',
    'https://byteisha.substack.com',
  ],
};

const nav = [
  { href: '/', label: 'Bio' },
  { href: '/experience', label: 'Experience' },
  { href: '/analytical-work', label: 'Publications & Reports' },
  { href: '/writing', label: 'Policy Commentary' },
  { href: '/courses', label: 'Courses' },
  { href: '/media', label: 'Media' },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <a href="/" class="brand">Bidisha Das</a>
        <nav class="site-nav">
          {nav.map(item => (
            <a href={item.href} aria-current={path === item.href ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} Bidisha Das</span>
        <span class="social">
          <a href="https://byteisha.substack.com" aria-label="Byteisha on Substack" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/bidishaimf" aria-label="LinkedIn profile" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.852 3.37-1.852 3.602 0 4.267 2.37 4.267 5.455v6.288zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </span>
      </footer>
    </div>
  </body>
</html>
