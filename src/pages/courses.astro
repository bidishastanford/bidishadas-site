---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Courses — Bidisha Das">
  <h1>Courses</h1>

  <h2>IMF Online Courses (edX)</h2>
  <div class="role">
    <div class="role-header">
      <h3>Monetary and Financial Statistics</h3>
      <span class="role-dates">IMFx · edX</span>
    </div>
    <p>
      Introduction to the compilation of monetary statistics covering the central bank,
      other depository corporations, and other financial corporations in accordance with
      international statistical standards. Presented by the IMF Statistics Department.
    </p>
  </div>

  <div class="role">
    <div class="role-header">
      <h3>Financial Soundness Indicators</h3>
      <span class="role-dates">IMFx · edX</span>
    </div>
    <p>
      Covers the collection, compilation, and analysis of Financial Soundness Indicators
      (FSIs) developed by the IMF. FSIs are used by researchers, analysts, and policymakers
      to assess strengths and vulnerabilities of financial systems for macroprudential
      monitoring.
    </p>
  </div>

  <h2>Stanford Graduate Courses</h2>
  <ul class="work-list">
    <li><strong>IPS 202</strong> — Topics in International Macroeconomics</li>
    <li><strong>IPS 203</strong> — Issues in International Economics</li>
  </ul>

  <h2>In-Person Training</h2>
  <p>
    Delivered training at IMF regional training centers in Singapore, Vienna,
    Abu Dhabi, Almaty, and Delhi.
  </p>
</BaseLayout>
