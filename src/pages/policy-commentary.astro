---
import BaseLayout from '../layouts/BaseLayout.astro';
import { XMLParser } from 'fast-xml-parser';

const FEED_URL = 'https://byteisha.substack.com/feed';
const NOTES_URL = 'https://byteisha.substack.com/api/v1/notes';

interface Post {
  title: string;
  link: string;
  pubDate: string;
  description?: string;
  image?: string;
}

interface Note {
  id: number;
  body: string;
  timestamp: string;
  url: string;
}

let posts: Post[] = [];
let fetchError: string | null = null;
let notes: Note[] = [];

function firstImage(html: string | undefined): string | undefined {
  if (!html) return undefined;
  const m = html.match(/<img[^>]+src=["']([^"']+)["']/i);
  return m ? m[1] : undefined;
}

try {
  const res = await fetch(FEED_URL);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const xml = await res.text();
  const parser = new XMLParser({ ignoreAttributes: false });
  const parsed = parser.parse(xml);
  const items = parsed?.rss?.channel?.item ?? [];
  const arr = Array.isArray(items) ? items : [items];
  posts = arr.slice(0, 7).map((it: any) => {
    const description = typeof it.description === 'string' ? it.description : undefined;
    const enclosure = it.enclosure?.['@_url'];
    return {
      title: String(it.title ?? ''),
      link: String(it.link ?? ''),
      pubDate: String(it.pubDate ?? ''),
      description,
      image: enclosure || firstImage(description),
    };
  });
} catch (err: any) {
  fetchError = err?.message ?? 'Could not load posts';
}

try {
  const res = await fetch(NOTES_URL);
  if (res.ok) {
    const data = await res.json();
    const items = data?.items ?? [];
    notes = items
      .filter((it: any) => it?.context?.type === 'note' && it?.comment?.body && it?.comment?.handle === 'byteisha')
      .slice(0, 4)
      .map((it: any) => ({
        id: it.comment.id,
        body: String(it.comment.body),
        timestamp: String(it.context?.timestamp ?? ''),
        url: `https://substack.com/@${it.comment.handle}/note/c-${it.comment.id}`,
      }));
  }
} catch {
  /* notes are optional; failure does not break the page */
}

function noteExcerpt(body: string, maxLen = 220): string {
  const cleaned = body
    .replace(/https?:\/\/\S+$/g, '')
    .replace(/\n+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  return cleaned.length > maxLen ? cleaned.slice(0, maxLen).replace(/\s\S*$/, '') + '…' : cleaned;
}

function noteDate(iso: string): string {
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  const sameYear = d.getFullYear() === new Date().getFullYear();
  return d.toLocaleDateString('en-US', sameYear
    ? { month: 'short', day: 'numeric' }
    : { month: 'short', day: 'numeric', year: 'numeric' });
}

function formatDate(d: string): string {
  const date = new Date(d);
  if (isNaN(date.getTime())) return d;
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function excerpt(html: string | undefined, maxLen = 220): string {
  if (!html) return '';
  const text = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  return text.length > maxLen ? text.slice(0, maxLen).replace(/\s\S*$/, '') + '…' : text;
}
---
<BaseLayout
  title="Policy Commentary — Bidisha Das"
  description="Policy commentary by Bidisha Das on the future of money, data, and the technologies reshaping both — crypto, stablecoins, CBDCs, tokenization, and financial data."
>
  <h1>Policy Commentary</h1>
  <p>
    I write at <a href="https://byteisha.substack.com" target="_blank" rel="noopener">Byteisha on Substack</a>
    on the future of money, data, and the technologies reshaping both.
  </p>
  <p class="disclaimer">
    <strong>Disclaimer:</strong> All views expressed here are strictly my own and do not
    reflect those of any institution, employer, affiliate, or organization I am
    associated with. This blog is a personal project and has no connection to my
    professional responsibilities.
  </p>

  {notes.length > 0 && (
    <section class="notes-strip" aria-label="Latest Substack notes">
      <div class="notes-strip-header">
        <h2>Latest Notes</h2>
        <a href="https://substack.com/@byteisha/notes" target="_blank" rel="noopener" class="notes-strip-more">All notes →</a>
      </div>
      <div class="notes-carousel">
        {notes.map(n => (
          <a class="note-card" href={n.url} target="_blank" rel="noopener">
            <span class="note-date">{noteDate(n.timestamp)}</span>
            <p class="note-body">{noteExcerpt(n.body)}</p>
            <span class="note-cta">View on Substack →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {fetchError && (
    <p><em>Posts could not be loaded ({fetchError}). Visit Substack directly.</em></p>
  )}

  {posts.length > 0 && (
    <div class="notes-strip-header">
      <h2>Latest Posts</h2>
      <a href="https://byteisha.substack.com/archive" target="_blank" rel="noopener" class="notes-strip-more">All posts →</a>
    </div>
  )}

  {posts.map(p => (
    <article class="post">
      {p.image && (
        <a href={p.link} target="_blank" rel="noopener" class="post-thumb">
          <img src={p.image} alt={p.title} loading="lazy" />
        </a>
      )}
      <div class="post-body">
        <span class="date">{formatDate(p.pubDate)}</span>
        <h3><a href={p.link} target="_blank" rel="noopener">{p.title}</a></h3>
        {p.description && <p>{excerpt(p.description)}</p>}
      </div>
    </article>
  ))}

  {posts.length >= 7 && (
    <p class="posts-more">
      <a href="https://byteisha.substack.com/archive" target="_blank" rel="noopener">
        Read more on Substack →
      </a>
    </p>
  )}
</BaseLayout>
