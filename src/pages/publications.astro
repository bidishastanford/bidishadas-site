---
<BaseLayout title="Publications & Reports — Bidisha Das">
  <h1>Publications &amp; Reports</h1>
  <p>
    A selection of policy papers, statistical guidance, country reports, and shorter
    pieces written or co-authored across roles at the IMF and World Bank.
  </p>

  <h2>Policy Papers</h2>
  <ul class="work-list">
    {policyPapers.map(p => (
      <li><a href={p.url} target="_blank" rel="noopener">{p.title}</a></li>
    ))}
  </ul>

  <h2>Statistical Guidance</h2>
  <ul class="work-list">
    {statisticalGuidance.map(p => (
      <li><a href={p.url} target="_blank" rel="noopener">{p.title}</a></li>
    ))}
  </ul>

  <h2>Reports</h2>
  <ul class="work-list">
    {reports.map(p => (
      <li><a href={p.url} target="_blank" rel="noopener">{p.title}</a></li>
    ))}
  </ul>

  <h2>Blogs</h2>
  <ul class="work-list">
    {blogs.map(p => (
      <li>
        <a href={p.url} target="_blank" rel="noopener">{p.title}</a>
        <span class="role-dates"> — {p.outlet}</span>
      </li>
    ))}
  </ul>
</BaseLayout>
